generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model arme {
  id                                        Int         @id @default(autoincrement())
  name                                      String      @db.VarChar(255)
  category                                  String      @db.VarChar(255)
  competenceArme                            Int
  damage                                    String?     @db.VarChar(255)
  average_dmg                               String?     @db.VarChar(255)
  range                                     String?     @db.VarChar(255)
  cadence                                   String?     @db.VarChar(255)
  capacity                                  String?     @db.VarChar(255)
  failure                                   Int?
  classic_price                             Float?      @db.Real
  modern_price                              Float?      @db.Real
  epoque                                    String[]    @db.VarChar(255)
  image_url                                 String?     @db.VarChar(255)
  competence_id                             Int?
  competence_arme_competence_idTocompetence Competence? @relation("arme_competence_idTocompetence", fields: [competence_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk3rjdk0p7fs5t2u0mtk27vmcy0")
  competence                                Competence  @relation("arme_competenceTocompetence", fields: [competenceArme], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_competenceArme_competence")
}

model artefact {
  id          Int     @id @default(autoincrement())
  name        String  @db.VarChar(255)
  use_by      String? @db.VarChar(255)
  description String?
  image_url   String? @db.VarChar(255)
}


model Competence {
  id              Int          @id @default(autoincrement())
  name            String
  categoryId      Int?         @map("category_id")
  baseValue       Int?         @map("base_value") @db.SmallInt
  isCategory      Boolean?     @map("is_category")
  rare            Boolean?
  modern          Boolean?
  // Self-relation
  category        Competence?  @relation("CompetenceCategory", fields: [categoryId], references: [id])
  children        Competence[] @relation("CompetenceCategory")
  weapons              arme[]                  @relation("arme_competenceTocompetence")
  weaponsOptional      arme[]                  @relation("arme_competence_idTocompetence")
  occupationSkills     OccupationSkill[]
  occupationSkillOpts  OccupationSkillOption[]
}


enum EntiteCategorie {
  CREATURE_MYTHE
  DIVINITE_MYTHE
  HORREUR_TRADITIONNEL
  FAUNE
}

// Entité principale — toutes catégories confondues
model Entite {
  id                   Int              @id @default(autoincrement())
  categorie            EntiteCategorie
  name                 String           @db.VarChar(255)
  // Sous-titre (ex : "Montures stellaires", "Source d'Impureté")
  titre                String?          @db.VarChar(255)
  // Citation littéraire séparée en texte + source
  citationTexte        String?
  citationSource       String?          @db.VarChar(512)
  // Lore / description générale
  description          String?

  // ── Combat ────────────────────────────────────────────────
  // Peut être "2" ou "1 (2 sous forme reptilienne)"
  attaquesParRound     String?          @db.VarChar(100)   @map("attaques_par_round")
  // Description textuelle des options de corps-à-corps
  optionsCombatDesc    String?          @map("options_combat_desc")
  protection           String?
  perteSanteMentale    String?          @db.VarChar(512)   @map("perte_sante_mentale")

  // ── Divinités uniquement ───────────────────────────────────
  culteAdoration       String?          @map("culte_adoration")
  autresParticularites String?          @map("autres_particularites")

  imageUrl             String?          @db.VarChar(512)   @map("image_url")

  statBlocks           EntiteStatBlock[]
  pouvoirs             EntitePouvoir[]
  attaques             EntiteAttaque[]
  competences          EntiteCompetence[]
}

// Bloc de caractéristiques — supporte les entités multi-formes
// Ex : Seigneurs shoggoths → 2 enregistrements (formeName = "Sous forme humaine" / "Sous forme de shoggoth")
// Ex : Lloigors → 1 enregistrement + formeNote expliquant les stats conditionnelles
// Ex : Abeilles → aucun enregistrement
model EntiteStatBlock {
  id         Int     @id @default(autoincrement())
  entiteId   Int     @map("entite_id")
  entite     Entite  @relation(fields: [entiteId], references: [id], onDelete: Cascade)

  // Nom de la forme (null = forme unique / seule)
  formeName  String? @db.VarChar(100)  @map("forme_name")
  // Note globale sur le bloc (ex : "* Sous forme reptilienne uniquement")
  formeNote  String? @db.VarChar(512)  @map("forme_note")
  sortOrder  Int     @default(0)       @map("sort_order")

  // Caractéristiques — String? pour gérer "—", "variable", chiffres
  // Chaque stat : valeur moyenne + formule de jet (null pour les divinités)
  forVal     String? @db.VarChar(50)  @map("for_val")
  forJet     String? @db.VarChar(50)  @map("for_jet")
  conVal     String? @db.VarChar(50)  @map("con_val")
  conJet     String? @db.VarChar(50)  @map("con_jet")
  taiVal     String? @db.VarChar(50)  @map("tai_val")
  taiJet     String? @db.VarChar(50)  @map("tai_jet")
  dexVal     String? @db.VarChar(50)  @map("dex_val")
  dexJet     String? @db.VarChar(50)  @map("dex_jet")
  intVal     String? @db.VarChar(50)  @map("int_val")
  intJet     String? @db.VarChar(50)  @map("int_jet")
  pouVal     String? @db.VarChar(50)  @map("pou_val")
  pouJet     String? @db.VarChar(50)  @map("pou_jet")
  // Uniquement humanoïdes (Seigneurs shoggoths forme humaine, PNJ...)
  appVal     String? @db.VarChar(50)  @map("app_val")
  appJet     String? @db.VarChar(50)  @map("app_jet")
  eduVal     String? @db.VarChar(50)  @map("edu_val")
  eduJet     String? @db.VarChar(50)  @map("edu_jet")

  // Stats dérivées (par forme pour les multi-formes)
  pvMoyen    String? @db.VarChar(50)  @map("pv_moyen")
  impactMoy  String? @db.VarChar(100) @map("impact_moy")
  carrureMoy String? @db.VarChar(50)  @map("carrure_moy")
  pmMoyen    String? @db.VarChar(50)  @map("pm_moyen")
  mouvement  String? @db.VarChar(255)
}

// POUVOIRS DISTINCTIFS (0..n par entité)
model EntitePouvoir {
  id          Int     @id @default(autoincrement())
  entiteId    Int     @map("entite_id")
  entite      Entite  @relation(fields: [entiteId], references: [id], onDelete: Cascade)
  name        String  @db.VarChar(255)
  description String
  sortOrder   Int     @default(0) @map("sort_order")
}

// Lignes de combat individuelles
// Couvre : "Combat rapproché 55 % (27/11), dégâts 1D6 + impact"
//          "Mordre et serrer (manœuvre) : dégâts 1D6 + 3D10 FOR"
//          "Esquive 35 % (17/7)"
//          "Absorber la force vitale : POU vs POU, ..."
model EntiteAttaque {
  id          Int     @id @default(autoincrement())
  entiteId    Int     @map("entite_id")
  entite      Entite  @relation(fields: [entiteId], references: [id], onDelete: Cascade)
  // Ex : "Combat rapproché", "Mordre et serrer", "Esquive", "Absorber la force vitale"
  name        String  @db.VarChar(255)
  // Ex : "55 % (27/11)" — null pour les attaques spéciales sans jet fixe
  valeur      String? @db.VarChar(100)
  // Ex : "1D6 + impact", "1D6 + 3D10 points de FOR"
  degats      String? @db.VarChar(255)
  isManoeuvre Boolean @default(false) @map("is_manoeuvre")
  // Effets/conditions supplémentaires (description longue)
  description String?
  sortOrder   Int     @default(0) @map("sort_order")
}

// Compétences listées en bas de fiche (ex : "Écouter 50 %", "Trouver Objet Caché 50 %")
model EntiteCompetence {
  id        Int     @id @default(autoincrement())
  entiteId  Int     @map("entite_id")
  entite    Entite  @relation(fields: [entiteId], references: [id], onDelete: Cascade)
  name      String  @db.VarChar(255)
  valeur    String  @db.VarChar(50)
  sortOrder Int     @default(0) @map("sort_order")
}

model equipement_classique {
  id         Int     @id @default(autoincrement())
  name       String  @db.VarChar(255)
  category   String? @db.VarChar(255)
  base_price Float   @db.Real
  max_price  Float?  @db.Real
  unit       String? @db.VarChar(255)
  superior   Boolean
}

model equipement_moderne {
  id         Int     @id @default(autoincrement())
  name       String  @db.VarChar(255)
  category   String? @db.VarChar(255)
  base_price Float   @db.Real
  max_price  Float?  @db.Real
  unit       String? @db.VarChar(255)
  superior   Boolean
}

model manie {
  id          Int    @id @default(autoincrement())
  name        String @db.VarChar(255)
  description String @db.VarChar(255)
}

enum OccupationSkillType {
  FIXED
  FIXED_SPEC
  FREE_SPEC
  CHOICE_FROM_LIST
  FREE_CHOICE
}

model occupation {
  id               Int                @id @default(autoincrement())
  name             String             @db.VarChar(255)
  credit_min       Int?
  credit_max       Int?
  point_competence String?            @db.VarChar(255)
  is_lovecraftian  Boolean            @default(false)
  is_modern        Boolean            @default(false)
  skills           OccupationSkill[]
}

model OccupationSkill {
  id            Int                    @id @default(autoincrement())
  occupationId  Int
  occupation    occupation             @relation(fields: [occupationId], references: [id], onDelete: Cascade)
  type          OccupationSkillType
  competenceId  Int?
  competence    Competence?            @relation(fields: [competenceId], references: [id], onDelete: SetNull)
  specName      String?                @db.VarChar(255)
  choiceCount   Int?
  note          String?                @db.VarChar(255)
  sortOrder     Int                    @default(0)
  options       OccupationSkillOption[]
}

model OccupationSkillOption {
  id                Int             @id @default(autoincrement())
  occupationSkillId Int
  occupationSkill   OccupationSkill @relation(fields: [occupationSkillId], references: [id], onDelete: Cascade)
  competenceId      Int
  competence        Competence      @relation(fields: [competenceId], references: [id], onDelete: Cascade)
}


model ouvrage_mythe {
  id                 Int            @id @default(autoincrement())
  titre              String         @db.VarChar(255)
  langue             String?        @db.VarChar(255)
  date               String?        @db.VarChar(255)
  auteur             String?        @db.VarChar(255)
  description        String?
  sante_mental       String?        @db.VarChar(255)
  gain_mythe_initial Int?
  gain_mythe_complet Int?
  mythe_cthulhu      Int?
  semaine            Int?
  ouvrage_sort       ouvrage_sort[]
}

model ouvrage_occulte {
  id          Int     @id @default(autoincrement())
  title       String? @db.VarChar(255)
  language    String? @db.VarChar(255)
  date        String? @db.VarChar(255)
  author      String? @db.VarChar(255)
  info        String? @db.VarChar(255)
  description String?
  sanity      String? @db.VarChar(255)
  occult_gain Int?
}

model ouvrage_sort {
  id               Int            @id @default(autoincrement())
  ouvrage_id       Int
  sort_id          Int?
  nom_dans_ouvrage String         @db.VarChar(255)
  note             String?        @db.VarChar(512)
  ouvrage_mythe    ouvrage_mythe  @relation(fields: [ouvrage_id], references: [id], onDelete: Cascade,  onUpdate: NoAction, map: "fk_ouvrageSort_ouvrageId")
  sort             sort?          @relation(fields: [sort_id], references: [id], onDelete: SetNull, onUpdate: NoAction, map: "fk_ouvrageSort_sortId")
}

model phobie {
  id          Int    @id @default(autoincrement())
  name        String @db.VarChar(255)
  description String @db.VarChar(255)
}


model sort {
  id                  Int            @id @default(autoincrement())
  name                String         @db.VarChar(255)
  cout                String?        @db.VarChar(512)
  temps_incantation   String?        @db.VarChar(255)
  description         String?
  version_approfondie String?
  autre_name          String[]       @db.VarChar(255)
  parentId            Int?
  parent              sort?          @relation("SortParent", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  children            sort[]         @relation("SortParent")
  ouvrage_sort        ouvrage_sort[]
}


model Investigateur {
  id        Int      @id @default(autoincrement())
  userId    String   @db.Uuid
  nom       String   @default("") @db.VarChar(255)
  data      Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
