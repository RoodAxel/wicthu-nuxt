generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Competence {
  id         Int      @id @default(autoincrement())
  name       String
  categoryId Int?     @map("category_id")
  baseValue  Int?     @map("base_value") @db.SmallInt
  isCategory Boolean? @map("is_category")
  rare       Boolean?
  modern     Boolean?

  // Self-relation
  category Competence?  @relation("CompetenceCategory", fields: [categoryId], references: [id])
  children Competence[] @relation("CompetenceCategory")
}
